{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "python3 ./.github/hooks/scripts/session_context.py",
        "timeout": 5
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "python3 ./.github/hooks/scripts/guard_destructive_commands.py",
        "timeout": 5
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "python3 ./.github/hooks/scripts/post_edit_validation_hint.py",
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python3 ./.github/hooks/scripts/auto_commit_changes.py",
        "timeout": 20,
        "env": {
          "AUTO_COMMIT_ENABLED": "true",
          "AUTO_COMMIT_MESSAGE_PREFIX": "chore: workspace updates",
          "AUTO_COMMIT_ONLY_SOURCE_FILES": "true",
          "AUTO_COMMIT_MIN_MATCHING_FILES": "2"
        }
      }
    ]
  }
}